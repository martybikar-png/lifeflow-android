# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.pro text eol=lf

# Gradle wrapper
gradlew text eol=lf
gradlew.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
